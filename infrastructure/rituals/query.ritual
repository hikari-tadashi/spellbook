# query.ritual
# Answers a natural language question using your Spellbook knowledge base.
#
# Usage:
#   spellbook query                                    (interactive prompt)
#   spellbook query what do I know about logic         (trailing args)
#   spellbook query --no-wikis what did I write about Mersault
#   echo "what is stoicism?" | spellbook query         (stdin pipe)
#
# Output: prose answer written for a human reader.
# For cited output, run: spellbook query-cited
python3 infrastructure/scripts/query_args_handler.py | python3 infrastructure/scripts/query_tagger.py | python3 infrastructure/scripts/wiki_retriever.py | python3 infrastructure/scripts/zettel_aggregator.py | python3 infrastructure/scripts/query_ranker.py | python3 infrastructure/scripts/context_assembler.py | python3 infrastructure/scripts/query_llm.py --mode prose
