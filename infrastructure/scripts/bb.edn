{:paths ["." "resources"]
 :deps  {}

 :tasks
 {;; ── package ───────────────────────────────────────────────────────────────
  ;; Produces a single executable installer script via `bb uberscript`.
  ;; Run from infrastructure/scripts/:
  ;;   bb package
  package
  {:doc      "Bundle install_spellbook.clj into a standalone executable installer"
   :requires ([babashka.fs :as fs] [clojure.string :as str])
   :task     (do

           (let [excluded-dirs  #{"old" "export" "__pycache__"}
                 excluded-files #{"bb-linux" "bb-mac"}
                 out-file       "spellbook-installer"
                 src-file       "install_spellbook.clj"
                 scripts-src    "."
                 rituals-src    (str (fs/path ".." "rituals"))]

             (println "[*] Staging resources …")

             (when-not (fs/exists? rituals-src)
               (println (str "[!] rituals dir not found: " rituals-src)))

             (letfn [(collect [dir ext-pred]
                       (->> (fs/list-dir dir)
                            (remove (fn [f]
                                      (and (fs/directory? f)
                                           (excluded-dirs (str (fs/file-name f))))))
                            (filter fs/regular-file?)
                            (map    (fn [f] (str (fs/file-name f))))
                            (remove excluded-files)
                            (filter ext-pred)
                            sort))]

               (let [scripts (collect scripts-src
                                      (fn [n]
                                        (and (or (str/ends-with? n ".py")
                                                 (str/ends-with? n ".sh")
                                                 (str/ends-with? n ".clj"))
                                             (not= n src-file))))
                     rituals (collect rituals-src
                                      (fn [n] (str/ends-with? n ".ritual")))]

                 (println (str "    scripts : " (str/join ", " scripts)))
                 (println (str "    rituals : " (str/join ", " rituals)))))

             (println (str "[*] Building uberscript → " out-file " …"))
             (when (fs/exists? out-file) (fs/delete out-file))
             (let [bb (if (str/starts-with? (str/lower-case (System/getProperty "os.name")) "windows")
                        (str (fs/absolutize "bb.exe")) "bb")]
               (shell bb "uberscript" out-file src-file))
             (.setExecutable (java.io.File. out-file) true)
             (println (str "[OK] Executable installer ready: "
                           (fs/absolutize out-file)))))}

  ;; ── build-exe ─────────────────────────────────────────────────────────────
  ;; Produces a fully self-contained install_spellbook.exe by concatenating
  ;; bb.exe with an uberjar.  Scripts (.py/.clj/.sh) and .ritual files are
  ;; embedded as classpath resources inside the JAR; no cabinet or IExpress.
  ;; Run from infrastructure/scripts/:
  ;;   bb build-exe
  build-exe
  {:doc      "Create a standalone install_spellbook.exe (bb.exe + uberjar, no IExpress)"
   :requires ([babashka.fs :as fs] [clojure.string :as str] [clojure.java.io :as io])
   :task     (do

     (let [excluded-dirs  #{"old" "export" "__pycache__"}
           excluded-files #{"bb-linux" "bb-mac"}
           scripts-src    (str (fs/absolutize "."))
           rituals-src    (str (fs/absolutize (fs/path ".." "rituals")))
           resources-dir  (str (fs/absolutize "resources"))
           jar-path       (str (fs/absolutize "install_spellbook.jar"))
           out-exe        (str (fs/absolutize "install_spellbook.exe"))
           bb-src         (str (fs/path scripts-src "bb.exe"))]

       ;; ── Prerequisites ───────────────────────────────────────────────────
       (when-not (fs/exists? bb-src)
         (println "[X] bb.exe not found in the scripts directory — cannot bundle it.")
         (println (str "    Expected: " bb-src))
         (System/exit 1))

       ;; ── Step 1: Populate classpath resources ────────────────────────────
       (println "[*] Step 1 — Staging classpath resources...")
       (letfn [(collect [dir pred]
                 (->> (fs/list-dir dir)
                      (remove (fn [f]
                                (and (fs/directory? f)
                                     (excluded-dirs (str (fs/file-name f))))))
                      (filter fs/regular-file?)
                      (map (fn [f] (str (fs/file-name f))))
                      (remove excluded-files)
                      (filter pred)
                      sort))]

         (let [scripts (collect scripts-src
                                 (fn [n]
                                   (and (or (str/ends-with? n ".py")
                                            (str/ends-with? n ".sh")
                                            (str/ends-with? n ".clj"))
                                        (not= n "install_spellbook.clj"))))
               rituals (if (fs/exists? rituals-src)
                         (collect rituals-src (fn [n] (str/ends-with? n ".ritual")))
                         (do (println "    [!] rituals/ dir not found — skipping") []))]

           (let [res-scripts (str (fs/path resources-dir "scripts"))
                 res-rituals (str (fs/path resources-dir "rituals"))]
             (fs/create-dirs res-scripts)
             (fs/create-dirs res-rituals)

             (doseq [s scripts]
               (fs/copy (str (fs/path scripts-src s))
                        (str (fs/path res-scripts s))
                        {:replace-existing true})
               (println (str "    + scripts/" s)))
             (spit (str (fs/path res-scripts "MANIFEST"))
                   (str/join "\n" scripts))

             (doseq [r rituals]
               (fs/copy (str (fs/path rituals-src r))
                        (str (fs/path res-rituals r))
                        {:replace-existing true})
               (println (str "    + rituals/" r)))
             (spit (str (fs/path res-rituals "MANIFEST"))
                   (str/join "\n" rituals)))
           (println)))

       ;; ── Step 2: Build uberjar ────────────────────────────────────────────
       (println "[*] Step 2 — Building uberjar...")
       (when (fs/exists? jar-path) (fs/delete jar-path))
       (let [bb (if (str/starts-with? (str/lower-case (System/getProperty "os.name")) "windows")
                  (str (fs/absolutize "bb.exe")) "bb")]
         (shell bb "uberjar" jar-path "-m" "install-spellbook"))
       (println)

       ;; ── Step 3: Concatenate bb.exe + jar → exe ───────────────────────────
       (println "[*] Step 3 — Concatenating bb.exe + jar -> install_spellbook.exe...")
       (when (fs/exists? out-exe) (fs/delete out-exe))
       (with-open [out (java.io.FileOutputStream. out-exe)]
         (doseq [f [bb-src jar-path]]
           (with-open [in (java.io.FileInputStream. f)]
             (io/copy in out))))
       (println (str "[OK] Executable ready: " out-exe))
       (println)

       ;; ── Cleanup ───────────────────────────────────────────────────────────
       (println "[*] Cleaning up resources and jar...")
       (fs/delete-tree resources-dir)
       (fs/delete jar-path)
       (println "[OK] Build complete!")))}

  ;; ── clean ─────────────────────────────────────────────────────────────────
  clean
  {:doc      "Remove build artefacts produced by `package` and `build-exe`"
   :requires ([babashka.fs :as fs])
   :task     (doseq [f ["spellbook-installer" "install_spellbook.exe" "install_spellbook.jar" "resources"]]
               (when (fs/exists? f)
                 (if (fs/directory? f)
                   (fs/delete-tree f)
                   (fs/delete f))
                 (println (str "[OK] Deleted: " f))))}}}
