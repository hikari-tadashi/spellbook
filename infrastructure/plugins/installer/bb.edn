{:paths ["."]
 :tasks
 {;; ── Path constants / shared helpers ──────────────────────────────────────
  ;; All paths relative to infrastructure/plugins/installer/ (where bb.edn lives).

  :init
  (do
    (require '[babashka.fs      :as fs]
             '[babashka.process :as proc]
             '[clojure.java.io  :as io]
             '[clojure.string   :as str])

    (def installer-dir (str (fs/absolutize ".")))
    (def bin-dir       (str (fs/path installer-dir "bin")))
    (def target-dir    (str (fs/path installer-dir "target")))
    (def dist-dir      (str (fs/path installer-dir "dist")))
    (def resources-dir (str (fs/path target-dir "resources")))
    (def jar-path      (str (fs/path target-dir "spellbook.jar")))

    ;; Two levels up from installer/ → infrastructure/
    (def infra-dir   (str (fs/absolutize "../..")))
    (def scripts-src (str (fs/path infra-dir "scripts")))
    (def rituals-src (str (fs/path infra-dir "rituals")))

    (def excluded-dirs  #{"old" "export" "__pycache__"})
    (def excluded-files #{"bb-linux" "bb-macos" "bb-windows.exe"})

    ;; NOTE: no #() anonymous fns — bb.edn is EDN-parsed before :init runs,
    ;; and #() is not valid EDN. Use (fn [...] ...) everywhere.

    (defn collect-files [dir ext-pred]
      (->> (fs/list-dir dir)
           (remove (fn [f]
                     (and (fs/directory? f)
                          (excluded-dirs (str (fs/file-name f))))))
           (filter fs/regular-file?)
           (map    (fn [f] (str (fs/file-name f))))
           (remove excluded-files)
           (filter ext-pred)
           sort))

    (defn human-size [path]
      (let [b (fs/size path)]
        (cond (> b 1048576) (format "%.1f MB" (/ b 1048576.0))
              (> b 1024)    (format "%.1f KB" (/ b 1024.0))
              :else         (str b " B"))))

    (defn windows-os? []
      (str/starts-with? (str/lower-case (System/getProperty "os.name")) "windows"))

    (defn sh! [& cmd]
      (let [result @(proc/process (vec cmd) {:out :inherit :err :inherit})]
        (when-not (zero? (:exit result))
          (throw (ex-info (str "Command failed: " (str/join " " cmd))
                          {:exit (:exit result)})))))

    (defn copy-files! [file-names src-dir dest-dir label]
      (doseq [fname file-names]
        (fs/copy (str (fs/path src-dir  fname))
                 (str (fs/path dest-dir fname))
                 {:replace-existing true})
        (println (str "    + " label "/" fname))))

    (defn write-manifest! [dir file-names]
      (spit (str (fs/path dir "MANIFEST"))
            (str/join "\n" file-names)))

    (defn concat-files! [sources dest-path]
      (with-open [out (java.io.FileOutputStream. dest-path)]
        (doseq [src sources]
          (with-open [in (java.io.FileInputStream. src)]
            (io/copy in out))))))

  ;; ── clean ─────────────────────────────────────────────────────────────────
  clean
  {:doc "Remove all build artifacts (target/ and dist/)"
   :task (do
           (doseq [d [target-dir dist-dir]]
             (when (fs/exists? d)
               (fs/delete-tree d)
               (println (str "[OK] Removed: " d))))
           (println "Clean complete."))}

  ;; ── stage-resources ───────────────────────────────────────────────────────
  stage-resources
  {:doc "Copy scripts and rituals into target/resources/ for embedding in the uberjar"
   :task (do
           (println "[*] Staging classpath resources...")
           (when-not (fs/exists? scripts-src)
             (throw (ex-info (str "scripts/ dir not found: " scripts-src) {})))
           (when-not (fs/exists? rituals-src)
             (throw (ex-info (str "rituals/ dir not found: " rituals-src) {})))

           (let [res-scripts (str (fs/path resources-dir "scripts"))
                 res-rituals (str (fs/path resources-dir "rituals"))

                 scripts (collect-files
                           scripts-src
                           (fn [n]
                             (and (or (str/ends-with? n ".py")
                                      (str/ends-with? n ".sh")
                                      (str/ends-with? n ".clj"))
                                  ;; The CLI entrypoint is the uberjar's main —
                                  ;; it doesn't need to be a resource too.
                                  (not= n "spellbook_cli.clj"))))

                 rituals (collect-files
                           rituals-src
                           (fn [n] (str/ends-with? n ".ritual")))]

             (fs/create-dirs res-scripts)
             (fs/create-dirs res-rituals)

             (println "    Scripts:")
             (copy-files! scripts scripts-src res-scripts "scripts")
             (write-manifest! res-scripts scripts)

             (println "    Rituals:")
             (copy-files! rituals rituals-src res-rituals "rituals")
             (write-manifest! res-rituals rituals)

             ;; Embed the platform bb binaries so install_spellbook.clj
             ;; can drop the right one during installation.
             (println "    BB binaries:")
             (doseq [bb-bin ["bb-linux" "bb-macos" "bb-windows.exe"]]
               (let [src (str (fs/path bin-dir bb-bin))]
                 (when (fs/exists? src)
                   (fs/copy src (str (fs/path res-scripts bb-bin)) {:replace-existing true})
                   (println (str "    + scripts/" bb-bin))))))

           (println "[OK] Resources staged.")
           (println))}

  ;; ── uberjar ───────────────────────────────────────────────────────────────
  uberjar
  {:doc "Build target/spellbook.jar (runs stage-resources first)"
   :depends [stage-resources]
   :task (do
           (println "[*] Building uberjar...")
           (when (fs/exists? jar-path) (fs/delete jar-path))
           (let [bb        (if (windows-os?) "bb.exe" "bb")
                 classpath (str scripts-src
                                (if (windows-os?) ";" ":")
                                resources-dir)]
             (sh! bb "uberjar" jar-path
                  "--classpath" classpath
                  "-m" "spellbook-cli"))
           (println (str "[OK] Uberjar → " jar-path " (" (human-size jar-path) ")"))
           (println))}

  ;; ── dist-linux ────────────────────────────────────────────────────────────
  dist-linux
  {:doc "Prepend bb-linux to the uberjar → a self-contained Linux binary"
   :depends [uberjar]
   :task (let [bb-bin (str (fs/path bin-dir "bb-linux"))
               out    (str (fs/path dist-dir "spellbook-linux"))]
           (println "[*] Building Linux binary...")
           (when-not (fs/exists? bb-bin)
             (throw (ex-info (str "bin/bb-linux not found: " bb-bin) {})))
           (fs/create-dirs dist-dir)
           ;; ZIP is read from the end of the file — prepending the ELF binary
           ;; is harmless; babashka detects the trailing ZIP on startup.
           (concat-files! [bb-bin jar-path] out)
           (fs/set-posix-file-permissions out "rwxr-xr-x")
           (println (str "[OK] Linux  → " out " (" (human-size out) ")"))
           (println))}

  ;; ── dist-macos ────────────────────────────────────────────────────────────
  dist-macos
  {:doc "Prepend bb-macos to the uberjar → a self-contained macOS binary"
   :depends [uberjar]
   :task (let [bb-bin (str (fs/path bin-dir "bb-macos"))
               out    (str (fs/path dist-dir "spellbook-macos"))]
           (println "[*] Building macOS binary...")
           (when-not (fs/exists? bb-bin)
             (throw (ex-info (str "bin/bb-macos not found: " bb-bin) {})))
           (fs/create-dirs dist-dir)
           (concat-files! [bb-bin jar-path] out)
           (fs/set-posix-file-permissions out "rwxr-xr-x")
           (println (str "[OK] macOS  → " out " (" (human-size out) ")"))
           (println))}

  ;; ── dist-windows ──────────────────────────────────────────────────────────
  ;; PE format is read from the beginning; ZIP is read from the end.
  ;; Babashka detects the trailing ZIP signature on startup — same trick as
  ;; Linux/macOS, no SFX module or extraction step required.
  dist-windows
  {:doc "Prepend bb-windows.exe to the uberjar → a self-contained Windows executable"
   :depends [uberjar]
   :task (let [bb-bin (str (fs/path bin-dir "bb-windows.exe"))
               out    (str (fs/path dist-dir "spellbook.exe"))]
           (println "[*] Building Windows executable...")
           (when-not (fs/exists? bb-bin)
             (throw (ex-info (str "bin/bb-windows.exe not found: " bb-bin) {})))
           (fs/create-dirs dist-dir)
           (concat-files! [bb-bin jar-path] out)
           (println (str "[OK] Windows → " out " (" (human-size out) ")"))
           (println))}

  ;; ── aggregate tasks ───────────────────────────────────────────────────────
  dist
  {:doc "Build distributions for all three platforms"
   :depends [dist-linux dist-macos dist-windows]
   :task (do
           (println "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
           (println "✦ All distributions ready:")
           (doseq [f ["spellbook-linux" "spellbook-macos" "spellbook.exe"]]
             (let [p (str (fs/path dist-dir f))]
               (when (fs/exists? p)
                 (println (str "    " p " (" (human-size p) ")")))))
           (println "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"))}

  dist-unix
  {:doc "Build Linux and macOS only (no 7z required)"
   :depends [dist-linux dist-macos]
   :task (println "✦ Unix distributions ready in dist/")}}}